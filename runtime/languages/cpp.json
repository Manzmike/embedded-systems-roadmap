{
  "id": "cpp",
  "name": "C++",
  "extensions": [".cpp", ".cc", ".cxx", ".hpp", ".h"],
  "entry": "main.cpp",
  "image": "gcc:13",
  "debugImage": "gcc:13",
  "build": ["g++", "-g", "-O0", "-std=c++20", "-Wall", "-Wextra", "-o", "{out}", "{files:.cpp,.cc,.cxx}"],
  "run": ["{out}"],
  "debugger": "gdb"
}
